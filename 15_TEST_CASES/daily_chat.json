      "expected_intent": "genuine",
      "expected_mode": "curious",
      "expected_action": "ask",
      "expected_output_contains": [
        "에?",
        "어떤 맛"
      ],
      "forbidden_output": [
        "관심없어",
        "그래서요"
      ],
      "source": "CF002"
